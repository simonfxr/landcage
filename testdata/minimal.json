{
  "name": "minimal-test",
  "fs": [
    { "path": "/usr", "access": "rx" },
    { "path": "/lib", "access": "rx", "ignore_missing": true },
    { "path": "/lib64", "access": "rx", "ignore_missing": true },
    { "path": "/etc", "access": "r" },
    { "path": "/dev/null", "access": "rw" },
    { "path": "/proc/self", "access": "r" },
    { "path": "{{ tmpDir }}", "access": "rwcd" }
  ]
}
